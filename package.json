{
  "name": "excalidraw-copilot",
  "displayName": "Excalidraw Copilot",
  "description": "Generate beautiful diagrams from natural language using GitHub Copilot — type @excalidraw in chat or right-click any file/folder",
  "version": "0.5.0",
  "publisher": "nadomani",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "excalidraw",
    "diagram",
    "ai",
    "copilot",
    "chat-participant",
    "mermaid",
    "architecture",
    "flowchart",
    "sequence-diagram",
    "system-design",
    "code-visualization"
  ],
  "activationEvents": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/nadomani/excalidraw-copilot"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "excalidraw-copilot.open",
        "title": "Excalidraw Copilot: Open Canvas"
      },
      {
        "command": "excalidraw-copilot.generate",
        "title": "Excalidraw Copilot: Generate Diagram"
      },
      {
        "command": "excalidraw-copilot.diagramFolder",
        "title": "Excalidraw Copilot: Diagram This Folder"
      },
      {
        "command": "excalidraw-copilot.diagramFile",
        "title": "Excalidraw Copilot: Diagram This File"
      },
      {
        "command": "excalidraw-copilot.diagramProject",
        "title": "Excalidraw Copilot: Diagram This Project"
      },
      {
        "command": "excalidraw-copilot.diagramSelection",
        "title": "Excalidraw Copilot: Diagram This Selection"
      },
      {
        "command": "excalidraw-copilot.saveDiagram",
        "title": "Excalidraw Copilot: Save Diagram",
        "icon": "$(save)"
      },
      {
        "command": "excalidraw-copilot.openDiagram",
        "title": "Excalidraw Copilot: Open Diagram"
      },
      {
        "command": "excalidraw-copilot.galleryOpen",
        "title": "Open Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "excalidraw-copilot.galleryDelete",
        "title": "Delete Diagram",
        "icon": "$(trash)"
      },
      {
        "command": "excalidraw-copilot.galleryRename",
        "title": "Rename Diagram",
        "icon": "$(edit)"
      },
      {
        "command": "excalidraw-copilot.galleryReveal",
        "title": "Reveal in Explorer",
        "icon": "$(folder-opened)"
      },
      {
        "command": "excalidraw-copilot.galleryRefine",
        "title": "Refine Diagram",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "excalidraw-copilot.galleryRefresh",
        "title": "Refresh Gallery",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "excalidraw-copilot.diagramFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "excalidraw-copilot.diagramFile",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "excalidraw-copilot.diagramProject",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "excalidraw-copilot.diagramFile",
          "group": "navigation"
        },
        {
          "command": "excalidraw-copilot.diagramSelection",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "excalidraw-copilot.galleryRefresh",
          "when": "view == excalidrawGallery",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "excalidraw-copilot.galleryOpen",
          "when": "view == excalidrawGallery",
          "group": "inline"
        },
        {
          "command": "excalidraw-copilot.galleryDelete",
          "when": "view == excalidrawGallery",
          "group": "context@1"
        },
        {
          "command": "excalidraw-copilot.galleryRename",
          "when": "view == excalidrawGallery",
          "group": "context@2"
        },
        {
          "command": "excalidraw-copilot.galleryReveal",
          "when": "view == excalidrawGallery",
          "group": "context@3"
        },
        {
          "command": "excalidraw-copilot.galleryRefine",
          "when": "view == excalidrawGallery",
          "group": "context@4"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "excalidraw-copilot.chat",
        "fullName": "Excalidraw Copilot",
        "name": "excalidraw",
        "description": "Generate beautiful diagrams from natural language — architecture, process flows, code visualization",
        "isSticky": true,
        "commands": [
          {
            "name": "new",
            "description": "Start a fresh diagram (ignore previous conversation)"
          },
          {
            "name": "diagram",
            "description": "Generate a diagram from a description"
          },
          {
            "name": "architecture",
            "description": "Generate an architecture diagram (Mermaid pipeline)"
          },
          {
            "name": "file",
            "description": "Diagram the structure of a file (use with #file reference)"
          },
          {
            "name": "folder",
            "description": "Diagram a folder's architecture"
          },
          {
            "name": "project",
            "description": "Diagram the entire workspace project"
          },
          {
            "name": "selection",
            "description": "Diagram the current code selection"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Excalidraw Copilot",
      "properties": {
        "excalidraw-copilot.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save diagrams to .excalidraw-copilot/ folder after generation"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "excalidraw-copilot",
          "title": "Excalidraw Diagrams",
          "icon": "$(preview)"
        }
      ]
    },
    "views": {
      "excalidraw-copilot": [
        {
          "id": "excalidrawGallery",
          "name": "Diagrams",
          "when": "workbenchState != empty"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "excalidrawGallery",
        "contents": "No saved diagrams yet.\nGenerate a diagram with @excalidraw in chat or the Command Palette — it'll appear here automatically.\n[Generate Diagram](command:excalidraw-copilot.generate)"
      }
    ],
    "customEditors": [
      {
        "viewType": "excalidraw-copilot.excalidrawEditor",
        "displayName": "Excalidraw Copilot",
        "selector": [
          {
            "filenamePattern": "*.excalidraw"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "lint": "eslint src --ext ts",
    "build:webview": "cd webview-ui && npm run build",
    "build": "npm run build:webview && npm run compile",
    "dev": "concurrently \"npm run watch\" \"cd webview-ui && npm run dev\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
